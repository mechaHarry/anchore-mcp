# Copy values into your MCP host environment (Cursor mcp.json `env`, shell export, etc.).
# Never commit real tokens.

# Required — Anchore Enterprise HTTPS API base (no trailing slash required)
ANCHORE_URL=https://anchore.example.com

# Required — API token (Basic auth with username _api_key)
ANCHORE_TOKEN=

# Optional — Anchore account header (x-anchore-account) when your deployment uses account demarcation
# ANCHORE_ACCOUNT=

# Optional — REST path version: v2 (default, Anchore Enterprise 5+) or v1 (legacy)
# ANCHORE_API_VERSION=v2

# Optional — idempotent GET retry (transient 429/502/503/504 and network errors). Timeouts are not retried.
# ANCHORE_HTTP_MAX_RETRIES=2
# ANCHORE_HTTP_RETRY_BASE_MS=300
# ANCHORE_HTTP_RETRY_MAX_MS=8000
